{
  "$schema": "../../node_modules/wrangler/config-schema.json",
  "name": "conduit-market",
  "compatibility_date": "2026-07-01",
  "pages_build_output_dir": "./dist",
  "services": [
    {
      "binding": "ANON_ZAP_RATE_LIMIT_SERVICE",
      "service": "conduit-anon-zap-signer",
    },
  ],
  "env": {
    "preview": {
      "services": [
        {
          "binding": "ANON_ZAP_RATE_LIMIT_SERVICE",
          "service": "conduit-anon-zap-signer-preview",
        },
      ],
    },
  },
}
