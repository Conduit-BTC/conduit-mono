{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@conduit/core": ["../../packages/core/src"],
      "@conduit/core/*": ["../../packages/core/src/*"],
      "@conduit/ui": ["../../packages/ui/src"],
      "@conduit/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
