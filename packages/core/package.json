{
  "name": "@conduit/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./types": "./src/types/index.ts",
    "./protocol": "./src/protocol/index.ts",
    "./schemas": "./src/schemas/index.ts",
    "./utils": "./src/utils/index.ts",
    "./config": "./src/config.ts",
    "./db": "./src/db/index.ts",
    "./billing": "./src/billing/entitlements.ts",
    "./context/*": "./src/context/*.tsx",
    "./hooks/*": "./src/hooks/*.ts"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --quiet",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@nostr-dev-kit/ndk": "^2.14.0",
    "clsx": "^2.1.1",
    "dexie": "^4.0.0",
    "tailwind-merge": "^3.3.0",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.62.8",
    "@types/react": "^19.0.2",
    "typescript": "^5.7.3"
  }
}
