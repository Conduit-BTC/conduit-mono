# Haven Merchant Relay - Dev Configuration
#
# This configures Haven for local development with permissive settings.
# WoT is disabled (depth=0) so all events are accepted without trust checks.
#
# See: https://github.com/barrydeen/haven

# Owner identity (dev-only test key)
OWNER_NPUB=npub1vm55savzly0csd88vza6wr0cffsswjkvzjjj4kjk85rp6wsfwdssptncne

# Relay URL and port
RELAY_URL=ws://127.0.0.1:3355
RELAY_PORT=3355
RELAY_BIND_ADDRESS=0.0.0.0

# Storage
DB_ENGINE=badger
BLOSSOM_PATH=/app/blossom

# Private relay metadata
PRIVATE_RELAY_NAME=Conduit Dev Private
PRIVATE_RELAY_NPUB=npub1vm55savzly0csd88vza6wr0cffsswjkvzjjj4kjk85rp6wsfwdssptncne
PRIVATE_RELAY_DESCRIPTION=Local dev private relay
PRIVATE_RELAY_ICON=https://placehold.co/64

# Chat relay metadata
CHAT_RELAY_NAME=Conduit Dev Chat
CHAT_RELAY_NPUB=npub1vm55savzly0csd88vza6wr0cffsswjkvzjjj4kjk85rp6wsfwdssptncne
CHAT_RELAY_DESCRIPTION=Local dev chat relay
CHAT_RELAY_ICON=https://placehold.co/64

# Outbox relay metadata
OUTBOX_RELAY_NAME=Conduit Dev Outbox
OUTBOX_RELAY_NPUB=npub1vm55savzly0csd88vza6wr0cffsswjkvzjjj4kjk85rp6wsfwdssptncne
OUTBOX_RELAY_DESCRIPTION=Local dev outbox (merchant products)
OUTBOX_RELAY_ICON=https://placehold.co/64

# Inbox relay metadata
INBOX_RELAY_NAME=Conduit Dev Inbox
INBOX_RELAY_NPUB=npub1vm55savzly0csd88vza6wr0cffsswjkvzjjj4kjk85rp6wsfwdssptncne
INBOX_RELAY_DESCRIPTION=Local dev inbox relay
INBOX_RELAY_ICON=https://placehold.co/64

# Disable Web of Trust for local dev (accept all events)
WOT_DEPTH=0

# Import config
IMPORT_START_DATE=2025-01-01
IMPORT_SEED_RELAYS_FILE=/app/relays_import.json
BLASTR_RELAYS_FILE=/app/relays_blastr.json

# Permissive rate limits for dev
INBOX_PULL_INTERVAL_SECONDS=30

# Logging
HAVEN_LOG_LEVEL=DEBUG

# Optional dev whitelist for extra publishers (npub array in JSON file)
WHITELISTED_NPUBS_FILE=/app/whitelist_npubs.dev.json

WHITELISTED_NPUBS_FILE=/app/whitelist_npubs.dev.json
