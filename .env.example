# Conduit Environment Configuration

# Optional relay overrides for forks/operators.
# Conduit-hosted deploys leave these empty; the canonical code list lives in packages/core/src/config.ts.
VITE_RELAY_URL=
VITE_DEFAULT_RELAY_URL=
VITE_DEFAULT_RELAYS=
VITE_APP_WRITE_RELAY_URLS=
VITE_PUBLIC_RELAY_URLS=
VITE_COMMERCE_RELAY_URLS=
VITE_CACHE_API_URL=

# Lightning network: mainnet | signet | testnet | mock
VITE_LIGHTNING_NETWORK=mainnet

# Blossom media server
VITE_BLOSSOM_SERVER_URL=https://blossom.conduit.market

# Aggregate analytics are disabled unless explicitly enabled.
# Pageview URLs are route-redacted before being sent to Plausible or PostHog.
VITE_ENABLE_TELEMETRY=false
# Optional comma-separated hostnames allowed to emit telemetry from this build.
VITE_TELEMETRY_ALLOWED_HOSTS=
# Plausible can use either a legacy domain or a site-specific script URL.
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SRC=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# NIP-89 application handler metadata
VITE_NIP89_RELAY_HINT=
VITE_NIP89_MARKET_PUBKEY=
VITE_NIP89_MERCHANT_PUBKEY=
VITE_NIP89_MARKET_D_TAG=conduit-market
VITE_NIP89_MERCHANT_D_TAG=conduit-merchant
