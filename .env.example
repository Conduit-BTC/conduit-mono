# Conduit Environment Configuration

# Optional relay overrides for forks/operators.
# Conduit-hosted deploys leave these empty; the canonical code list lives in packages/core/src/config.ts.
VITE_RELAY_URL=
VITE_DEFAULT_RELAY_URL=
VITE_DEFAULT_RELAYS=
VITE_APP_WRITE_RELAY_URLS=
VITE_PUBLIC_RELAY_URLS=
VITE_COMMERCE_RELAY_URLS=
VITE_CACHE_API_URL=

# Lightning network: mainnet | signet | testnet | mock
VITE_LIGHTNING_NETWORK=mainnet

# Blossom media server
VITE_BLOSSOM_SERVER_URL=https://blossom.conduit.market

# Aggregate analytics are disabled unless explicitly enabled.
# Pageview URLs are route-redacted before being sent to Plausible or PostHog.
VITE_ENABLE_TELEMETRY=false
# Optional comma-separated hostnames allowed to emit telemetry from this build.
VITE_TELEMETRY_ALLOWED_HOSTS=
# Plausible can use either a legacy domain or a site-specific script URL.
VITE_PLAUSIBLE_DOMAIN=
VITE_PLAUSIBLE_SRC=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=

# NIP-89 application handler metadata
VITE_NIP89_RELAY_HINT=
VITE_NIP89_MARKET_PUBKEY=
VITE_NIP89_MERCHANT_PUBKEY=
VITE_NIP89_MARKET_D_TAG=conduit-market
VITE_NIP89_MERCHANT_D_TAG=conduit-merchant

# Public Anon Conduit Shopper signer config. Point the browser at a trusted
# Market endpoint/proxy, not the raw Worker when request auth is required.
VITE_ANON_ZAP_SIGNER_URL=
VITE_ANON_ZAP_SIGNER_PUBKEY=

# Current Pages-function origin allow-list.
ANON_ZAP_ALLOWED_ORIGINS=

# Server-side inputs owned by the dependent trusted checkout proxy. This
# signer-handoff change does not wire that proxy; setting these values alone
# does not enable the current fail-closed Pages endpoints. The request auth
# secret must never be exposed through VITE_* client env vars.
ANON_ZAP_SIGNER_URL=
ANON_SIGNER_REQUEST_AUTH_SECRET=
ANON_ZAP_COMMERCE_RELAYS=
ANON_ZAP_RECEIPT_RELAYS=
ANON_ZAP_AUTH_TTL_SECONDS=

# Local/dev Anon signer service config. Put real values only in `.env.local`
# or the server-side signer deployment secret; never commit the private key.
ANON_CONDUIT_SHOPPER_PRIVATE_KEY_HEX=
ANON_CONDUIT_SHOPPER_PUBKEY=
ANON_SIGNER_ALLOWED_ORIGINS=http://localhost:7000,http://127.0.0.1:7000
ANON_SIGNER_MAX_CLOCK_SKEW_SECONDS=300
ANON_SIGNER_PORT=7010
