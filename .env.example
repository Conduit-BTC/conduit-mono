# Conduit Environment Configuration

# Primary relay URL
VITE_RELAY_URL=wss://relay.conduit.market

# Additional relays (comma-separated, added to defaults)
VITE_DEFAULT_RELAYS=

# Lightning network: mainnet | testnet | mock
VITE_LIGHTNING_NETWORK=mainnet

# Blossom media server
VITE_BLOSSOM_SERVER_URL=https://blossom.conduit.market

# ── Relay Role URLs (comma-separated) ──────────────────────────
#
# These configure the three relay tiers in the commerce read gateway.
# For local development with the relay stack (bun run relay:stack:up):
#
#   VITE_L2_RELAY_URLS=ws://127.0.0.1:3334
#   VITE_MERCHANT_RELAY_URLS=ws://127.0.0.1:3355
#   VITE_PUBLIC_RELAY_URLS=ws://127.0.0.1:7777

# L2 relay: commerce-aware queries, sorting, search (Conduit L2 Scope 2)
VITE_L2_RELAY_URLS=

# Merchant relay: source-of-truth for merchant products (Haven outbox)
VITE_MERCHANT_RELAY_URLS=

# Public relays: general Nostr network relays
VITE_PUBLIC_RELAY_URLS=

# Cache API: application-performance layer (future, Scope 3)
VITE_CACHE_API_URL=
